{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["status", "schema_version", "session_id", "method", "estimates", "provenance"],
  "properties": {
    "status": {"const": "llm_estimates"},
    "schema_version": {"type": "string"},
    "session_id": {"type": "string"},
    "method": {"const": "llm_corpus_analysis"},
    "disclaimer": {"type": "string"},
    "estimates": {
      "type": "object",
      "minProperties": 4,
      "additionalProperties": {
        "type": "object",
        "required": ["metric_id", "title_ru", "value_human", "confidence", "evidence_quotes"],
        "properties": {
          "metric_id": {"type": "string"},
          "title_ru": {"type": "string"},
          "value_human": {"type": "string"},
          "numeric_estimate": {},
          "scale": {"type": "string"},
          "interpretation": {"type": "string"},
          "confidence": {"enum": ["low", "medium", "high"]},
          "evidence_quotes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["source_id", "text"],
              "properties": {
                "source_id": {"type": "string"},
                "text": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["replaces_parser_metrics", "not_a_substitute_for_parser"],
      "properties": {
        "replaces_parser_metrics": {"type": "boolean"},
        "not_a_substitute_for_parser": {"type": "boolean"}
      }
    }
  },
  "additionalProperties": false
}
