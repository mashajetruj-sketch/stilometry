{
  "schema_version": "1.0",
  "manifest_version": "1.0.0",
  "implementation": "stilometry-core",
  "implementation_version": "0.2.0",
  "metrics": [
    {"id":"avg_word_length","type":"scalar","unit":"chars","formula":"sum(word lengths)/N_words","version":"1.0"},
    {"id":"ttr","type":"scalar","unit":"ratio","formula":"unique word forms/N_words","version":"1.0"},
    {"id":"mtld","type":"scalar","unit":"tokens","formula":"mean factor lengths at TTR<0.72","version":"1.0"},
    {"id":"function_word_ratio","type":"scalar","unit":"ratio","formula":"function lemmas/N_words","version":"1.0"},
    {"id":"hapax_ratio","type":"scalar","unit":"ratio","formula":"lemmas occurring once/unique lemmas","version":"1.0"},
    {"id":"avg_sentence_length","type":"scalar","unit":"words","formula":"N_words/N_sentences","version":"1.0"},
    {"id":"complex_sentence_ratio","type":"scalar","unit":"ratio","formula":"sentences with >=2 finite verbs/N_sentences via slovnet morph","version":"1.0"},
    {"id":"dependency_tree_depth","type":"scalar","unit":"depth","formula":"median parser tree depth","version":"1.0"},
    {"id":"avg_noun_phrase_length","type":"scalar","unit":"tokens","formula":"mean parser noun phrase length","version":"1.0"},
    {"id":"passive_impersonal_ratio","type":"scalar","unit":"ratio","formula":"nsubj:pass|aux:pass|Voice=Pass sentences/N_sentences via slovnet syntax+morph","version":"1.0"},
    {"id":"pos_entropy","type":"scalar","unit":"bits","formula":"heuristic FUNCTION-vs-WORD buckets only; not POS tagging","version":"1.0"},
    {"id":"verb_ratio","type":"scalar","unit":"ratio","formula":"heuristic verb suffix matches/N_words; not POS tagging","version":"1.0"},
    {"id":"adjective_participle_ratio","type":"scalar","unit":"ratio","formula":"heuristic adjective suffix matches/N_words; not POS tagging","version":"1.0"},
    {"id":"morphological_variability","type":"scalar","unit":"ratio","formula":"heuristic word+length-bucket signatures/N_words; not morphology","version":"1.0"},
    {"id":"punctuation_density","type":"scalar","unit":"per_1000_words","formula":"N_punct/N_words*1000","version":"1.0"},
    {"id":"punctuation_profile","type":"vector","unit":"ratio","formula":"count(mark)/N_punct for configured marks","version":"1.0"},
    {"id":"question_exclamation_ratio","type":"scalar","unit":"ratio","formula":"sentences ending ? or !/N_sentences","version":"1.0"},
    {"id":"sentence_length_cv","type":"scalar","unit":"ratio","formula":"population sd(sentence lengths)/mean","version":"1.0"},
    {"id":"short_long_sentence_ratio","type":"vector","unit":"ratio","formula":"short<8 and long>30/N_sentences","version":"1.0"},
    {"id":"paragraph_burstiness","type":"vector","unit":"ratio","formula":"sd(paragraph lengths)/mean and median","version":"1.0"},
    {"id":"repeated_ngram_rhythm","type":"scalar","unit":"ratio","formula":"repeated bigrams/trigrams occurrences/N_words","version":"1.0"},
    {"id":"discourse_marker_ratio","type":"scalar","unit":"per_sentence","formula":"marker hits/N_sentences","version":"1.0"},
    {"id":"figurative_candidate_ratio","type":"scalar","unit":"per_1000_words","formula":"comparison/figurative marker hits/N_words*1000 (heuristic)","version":"1.0"},
    {"id":"anaphora_ratio","type":"scalar","unit":"ratio","formula":"repeated sentence-initial forms/N_sentences","version":"1.0"},
    {"id":"modality_hedging_ratio","type":"scalar","unit":"per_sentence","formula":"modal lexicon hits/N_sentences","version":"1.0"},
    {"id":"evaluation_emotion_ratio","type":"scalar","unit":"ratio","formula":"affect lexicon hits/N_words","version":"1.0"},
    {"id":"direct_address_ratio","type":"scalar","unit":"per_sentence","formula":"second-person/questions/imperatives/N_sentences","version":"1.0"},
    {"id":"digital_markup_signature","type":"vector","unit":"per_1000_chars","formula":"counts of URL/hash/mention/emoji/code/mixing/repeated punctuation/emoticon","version":"1.0"}
  ]
}
